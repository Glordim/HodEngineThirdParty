      "steps": [
        { "type": "configure", "name": "android-arm64-v8a" },
        { "type": "build",     "name": "android-arm64-v8a" },
        { "type": "build",     "name": "android-arm64-v8a-install" }
      ]
    },
    {
      "name": "android-x86_64",
      "displayName": "Android x86_64 — configure, build, install",
      "steps": [
        { "type": "configure", "name": "android-x86_64" },
        { "type": "build",     "name": "android-x86_64" },
        { "type": "build",     "name": "android-x86_64-install" }
      ]
    }
